# Supabase (frontend + backend)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Supabase (solo backend / API routes en Vercel)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Lemon Squeezy (pagos)
LEMONSQUEEZY_API_KEY=...           # Settings → API en app.lemonsqueezy.com
LEMONSQUEEZY_STORE_ID=...          # número de tu tienda (ej: 12345)
LEMONSQUEEZY_VARIANT_BASE=...      # ID del variant Plan Base $11.45/mes
LEMONSQUEEZY_VARIANT_TURBO=...     # ID del variant Plan Turbo $19.20/mes
LEMONSQUEEZY_WEBHOOK_SECRET=...    # Settings → Webhooks → signing secret

# App
APP_URL=https://mechaia.app
