# Supabase (frontend + backend)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Supabase (solo backend / API routes en Vercel)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Anthropic (chat / diagnostico — ya viene con billing por defecto)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI — embeddings para el RAG (Gemini gemini-embedding-001).
# IMPORTANTE: usar 2 keys diferentes para que un script de ingest masivo
# nunca pueda agotar la cuota de la app en producción.
#
# GOOGLE_AI_API_KEY        → solo la usa /api/diagnose en Vercel (prod, billing ON).
# GOOGLE_AI_API_KEY_INGEST → solo la usan los scripts/ingest-* y scripts/seed-*
#                            (puede ser otro proyecto Google con free tier o billing).
#
# Si solo seteás GOOGLE_AI_API_KEY, los scripts caen a esa por fallback (riesgoso
# porque un ingest masivo agota los 1000 req/dia del free tier y tira la app abajo).
GOOGLE_AI_API_KEY=AIza...
GOOGLE_AI_API_KEY_INGEST=AIza...

# Lemon Squeezy (pagos)
LEMONSQUEEZY_API_KEY=...           # Settings → API en app.lemonsqueezy.com
LEMONSQUEEZY_STORE_ID=...          # número de tu tienda (ej: 12345)
LEMONSQUEEZY_VARIANT_BASE=...      # ID del variant Plan Base $11.45/mes
LEMONSQUEEZY_VARIANT_TURBO=...     # ID del variant Plan Turbo $19.20/mes
LEMONSQUEEZY_WEBHOOK_SECRET=...    # Settings → Webhooks → signing secret

# App
APP_URL=https://mechaia.app
